<form action="<%= submitPath %>?_csrf=<%= locals.csrfToken %>" method="post" enctype="multipart/form-data" >

               <p>
                    <label for="title">Title</label>
                    <input type="text" id="title" name="title" value="<%= product.title %>" required>
               </p>
               <div id="image-upload-control">
                    <p>
                      <label for="image">Product Image</label>
                      <input type="file" id="image" name="image" accept="image/png, image/jpg" <% if(imageRequired) {%>required <% } %>  >
                    </p>
                    <img src=" " alt="image preview">
               </div>

               <p>
                    <label for="summary">Product Summary</label>
                    <input type="text" name="summary" id="summary" value="<%= product.summary %>" required maxlength="250">
               </p>
               <p>
                    <label for="price">Product Price</label>
                    <input type="number" name="price" id="price" min="0.01" step="0.01" value="<%= product.price %>" required>
               </p>
               <p>
                    <label for="description">Product Description</label>
                    <textarea id="description" name="description" row="7"  required><%= product.description %></textarea>
               </p>
               <p>
                    <button type="reset" class="btn btn-alt" >reset</button>
                    <button class="btn">Save</button>
               </p>
          </form>