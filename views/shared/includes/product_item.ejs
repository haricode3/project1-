<article class="product-item">
     <img src="<%= product.imageUrl %>" alt="">
     <div id="product-item-content">
          <h2>
               <%= product.title %>
          </h2>
          <div id="product-item-actions">
               <% if(locals.isAdmin ){ %>
                    <a href="/admin/products/<%= product._id %>" class="btn btn-alt">View and edit</a>
                    <button class="btn btn-alt" data-prodid="<%= product._id %>" data-csrf="<%= locals.csrfToken %>"  >Delete</button>
               <% } else{ %>
                    <a class="btn btn-alt" href="/products/<%= product._id %>">View Details</a>
               <% } %>
               

          </div>
     </div>
</article>