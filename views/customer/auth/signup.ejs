<%- include('../../shared/includes/head',{pageTitle: 'signup'}) %>
<link rel="stylesheet" href="/styles/forms.css">
<link rel="stylesheet" href="/styles/auth.css">
<link rel="stylesheet" href="/styles/base.css">

</head>
<body>
     <%- include('../../shared/includes/header') %>
     <main>
          <h1>Create New Account</h1>
          <% if( inputData.errormessage ) {%>
               <section class="alert">
                    <h2>Invalid Input</h2>
                    <p><%= inputData.errormessage %></p>
                    
               </section> 
          <% } %>
          <form action="/signup" method="post">
               <input type="hidden" name="_csrf" value="<%= locals.csrfToken  %>">
               <p>
                    <label for="email">Enter Email </label>
                    <input type="email" name="email" id="email" value="<%= inputData.email %>" required>
               </p>
               <p>
                    <label for="password" >Enter Password</label>
                    <input type="password" id="password" name="password" minlength="6" value="<%= inputData.password %>" required>
               </p>
               <p>
                    <label for="confirm-password">Confirm password</label>
                    <input type="password" name="confirm-password" id="confirm-password" value="<%= inputData.confirmPassword %>" required>
               </p>
               <hr>
               <p>
                    <label for="name" >Enter Full Name</label>
                    <input type="text" id="name" name="name" value="<%= inputData.name %>" required>
               </p>
               <p>
                    <label for="street">Enter Current street</label>
                    <input type="text" id="street" name="street" value="<%= inputData.street %>" required>
               </p>
               <p>
                    <label for="postal">Enter Postal code</label>
                    <input type="text" id="postal" name="postal" value="<%= inputData.postal %>" required>

               </p>
               <button class="btn" >Submit</button>
               <p id="switch-form"><a href="/login">Login instead</a></p>

          </form>
     </main>

<%- include('../../shared/includes/footer')  %>